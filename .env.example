# Copy to .env and fill in values. Never commit .env.

# Required for ingestion / TBA-backed features
TBA_API_KEY=your_tba_api_key_here

# PostgreSQL (async driver for the FastAPI app)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/statfrc

# Optional: sync driver for scripts that use psycopg2
# DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/statfrc

# Optional Redis (if used by future features)
# REDIS_URL=redis://localhost:6379/0

# Optional: win-probability tuning (defaults in backend/config.py)
# PREDICTION_PROB_SHRINK=0.92
# PREDICTION_Z_TEMPERATURE=1.04
# PREDICTION_ML_BLEND_WEIGHT=0.42
# PREDICTION_DEFENSE_BLEND=0.18

# Optional: protect POST /api/ingest/bulk — send the same value as header X-Bulk-Ingest-Secret
# BULK_INGEST_SECRET=your_long_random_string
