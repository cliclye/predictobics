# Copy to .env and fill in values. Never commit .env.

# Required for ingestion / TBA-backed features
TBA_API_KEY=your_tba_api_key_here

# PostgreSQL (async driver for the FastAPI app)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/statfrc

# Optional: sync driver for scripts that use psycopg2
# DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/statfrc

# Optional Redis (if used by future features)
# REDIS_URL=redis://localhost:6379/0

# Optional: win-probability tuning (defaults in backend/config.py)
# PREDICTION_PROB_SHRINK=0.92
# PREDICTION_Z_TEMPERATURE=1.04
# PREDICTION_ML_BLEND_WEIGHT=0.42
# PREDICTION_DEFENSE_BLEND=0.18

# Optional: shared secret for all write/admin POSTs (ingest, compute, train, bulk).
# Send as header X-Admin-Secret or X-Bulk-Ingest-Secret (same value).
# ADMIN_API_SECRET=your_long_random_string

# Legacy name: if set (and ADMIN_API_SECRET is empty), same behavior as ADMIN_API_SECRET.
# BULK_INGEST_SECRET=your_long_random_string

# Optional: browser CORS allowlist (comma-separated). Default * = any origin.
# CORS_ORIGINS=https://your-app.vercel.app,https://www.example.com

# --- Vercel (serverless proxy; not read by FastAPI) ---
# If the React app is on Vercel and the API is elsewhere, add this in Vercel → Environment Variables:
# BACKEND_ORIGIN=https://your-fastapi-host.up.railway.app
# (HTTPS origin only — no path, no trailing slash). The proxy forwards /api/* to BACKEND_ORIGIN/api/*
# Alternative: build the frontend with REACT_APP_API_URL=https://your-api.../api (then CORS must allow your Vercel domain).
