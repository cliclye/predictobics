{
  "name": "predictobics-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Predictobics web UI (React)",
  "license": "MIT",
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.15.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "api": "cd .. && PYTHONPATH=. ./venv/bin/python -m uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000",
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm run api\" \"react-scripts start\""
  },
  "proxy": "http://127.0.0.1:8000",
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cliclye/predictobics.git"
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  }
}
